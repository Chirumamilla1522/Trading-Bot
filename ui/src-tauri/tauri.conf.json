{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agentic Trading Terminal",
  "version": "0.2.0",
  "identifier": "com.tradingdesk.terminal",
  "build": {
    "beforeDevCommand":   "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl":             "http://localhost:1420",
    "frontendDist":       "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title":     "Agentic Trading Terminal",
        "width":     1920,
        "height":    1080,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:8000 https://fonts.googleapis.com https://fonts.gstatic.com tauri: asset: data: blob:; connect-src 'self' http://localhost:8000 ws://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
